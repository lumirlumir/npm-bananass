{
  "name": "eslint-config-bananass",
  "version": "0.7.0",
  "type": "module",
  "description": "ESLint Config for Bananass Framework.🍌",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./src/index.js"
    },
    "./js": {
      "types": "./build/configs/js.d.ts",
      "default": "./src/configs/js.js"
    },
    "./ts": {
      "types": "./build/configs/ts.d.ts",
      "default": "./src/configs/ts.js"
    },
    "./jsx-react": {
      "types": "./build/configs/jsx-react.d.ts",
      "default": "./src/configs/jsx-react.js"
    },
    "./jsx-next": {
      "types": "./build/configs/jsx-next.d.ts",
      "default": "./src/configs/jsx-next.js"
    },
    "./tsx-react": {
      "types": "./build/configs/tsx-react.d.ts",
      "default": "./src/configs/tsx-react.js"
    },
    "./tsx-next": {
      "types": "./build/configs/tsx-next.d.ts",
      "default": "./src/configs/tsx-next.js"
    },
    "./json": {
      "types": "./build/configs/json.d.ts",
      "default": "./src/configs/json.js"
    },
    "./jsonc": {
      "types": "./build/configs/jsonc.d.ts",
      "default": "./src/configs/jsonc.js"
    },
    "./json5": {
      "types": "./build/configs/json5.d.ts",
      "default": "./src/configs/json5.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./build/*"
      ],
      ".": [
        "./build/index.d.ts"
      ],
      "js": [
        "./build/configs/js.d.ts"
      ],
      "ts": [
        "./build/configs/ts.d.ts"
      ],
      "jsx-react": [
        "./build/configs/jsx-react.d.ts"
      ],
      "jsx-next": [
        "./build/configs/jsx-next.d.ts"
      ],
      "tsx-react": [
        "./build/configs/tsx-react.d.ts"
      ],
      "tsx-next": [
        "./build/configs/tsx-next.d.ts"
      ],
      "json": [
        "./build/configs/json.d.ts"
      ],
      "jsonc": [
        "./build/configs/jsonc.d.ts"
      ],
      "json5": [
        "./build/configs/json5.d.ts"
      ]
    }
  },
  "files": [
    "src",
    "build",
    "LICENSE.md",
    "README.md",
    "!src/**/*.test.{js,ts}",
    "!**/fixtures/**"
  ],
  "keywords": [
    "bananass",
    "baekjoon",
    "framework",
    "javascript",
    "eslint",
    "eslintconfig",
    "eslint-config",
    "config",
    "flat",
    "flat-config",
    "typescript",
    "react",
    "nextjs",
    "js",
    "ts",
    "jsx",
    "tsx",
    "json",
    "jsonc",
    "json5"
  ],
  "author": "lumir <rpfos@naver.com> (https://github.com/lumirlumir)",
  "funding": "https://github.com/sponsors/lumirlumir",
  "license": "MIT",
  "homepage": "https://bananass.lumir.page",
  "repository": {
    "type": "github",
    "url": "git+https://github.com/lumirlumir/npm-bananass.git",
    "directory": "packages/eslint-config-bananass"
  },
  "bugs": {
    "url": "https://github.com/lumirlumir/npm-bananass/issues"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && node ../../scripts/cp.js ../../LICENSE.md LICENSE.md ../../README.md README.md",
    "test": "node --test"
  },
  "peerDependencies": {
    "eslint": "^9.35.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/json": "^0.14.0",
    "@next/eslint-plugin-next": "^16.2.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.4.0"
  },
  "devDependencies": {
    "@types/eslint-plugin-jsx-a11y": "^6.10.1"
  }
}
